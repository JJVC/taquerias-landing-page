  <div class="container">
    <div class="proof-content">
      <div class="proof-stat">
        <span class="stat-number">+25</span>
        <span class="stat-label">Años de Experiencia</span>
      </div>
      <div class="proof-stat">
        <span class="stat-number">⭐⭐⭐⭐⭐</span>
