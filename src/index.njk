      </div>
      <div class="proof-stat">
        <span class="stat-number">100%</span>
        <span class="stat-label">Carne de Calidad</span>
      </div>
    </div>
  </div>
</section-->

<!-- Promociones Section -->
<section class="promociones"
  id="promociones"
        data-fecha-inicio="{{ data.promociones.temporal.fechaInicio }}" 
        data-fecha-fin="{{ data.promociones.temporal.fechaFin }}">
  <div class="container">
    <h2 class="section-title">Aprovecha Nuestras Promociones</h2>
    
    <div class="promociones-grid">
      {% for promo in data.promociones.lista %}
      <div class="promo-card promo-cortesia">
        <div class="promo-header">
          <span class="promo-emoji">{{ promo.icono }}</span>
          <h3>{{ promo.titulo }}</h3>
        </div>
        <p>{{ promo.descripcion }}</p>
        <p class="promo-minimo badge">Por: <strong>${{ promo.monto }}</strong></p>
        <p class="promo-acciones-label">Selecciona tu bebida y utiliza el cupón:</p>
        <div class="promo-actions">
          {% for action in promo.action %}
           <a href="https://wa.me/{{ whatsappNumber }}?text={{ (action.messageWhatsApp ~ ' Cupón: PLACEHOLDER') | urlencode }}" name="btn_promociones"
             class="btn btn-secondary"
             target="_blank">
            {{ action.nombre }} {% include "icons/whatsapp.njk" %}
          </a>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
      
    </div>
    
    <p class="promociones-nota">⚠️ {{ data.promociones.nota }}</p>
  </div>
</section>

<!-- Galería del Local -->
<section class="galeria-section">
  <div class="container">
    <h2 class="section-title">Conoce Nuestro Local</h2>
    <p class="section-subtitle">Un ambiente familiar frente a la U.H. Gaviotas de {{ data.contacto.ubicacion.colonia }}</p>
    
    <div class="galeria-content">
      <div class="galeria-image">
        <img src="{{ data.assets.fachada }}" alt="Fachada de {{ data.nombre }}" loading="lazy">
      </div>
      <div class="galeria-text">
        <h3>📍 Nos encontramos en {{ data.contacto.ubicacion.colonia }}</h3>
        <p>Un local acogedor donde la tradición y el sabor se encuentran. Ven a disfrutar de nuestros tacos en un ambiente familiar.</p>
        <ul class="galeria-features">
          <li>✓ Espacio limpio y cómodo</li>
          <li>✓ Atención personalizada</li>
          <li>✓ Preparación a la vista</li>
          <li>✓ Para comer aquí o llevar</li>
        </ul>
        <a href="{{ data.contacto.ubicacion.googleMapsUrl }}" 
           target="_blank"
           class="btn btn-primary">
          📍 Cómo Llegar
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Horarios y Ubicación -->
<section class="info-section">
  <div class="container">
    <div class="info-grid">
      <!-- Horarios -->
      <div class="info-card">
        <div class="info-icon">🕒</div>
        <h3>Horarios</h3>
        <p class="info-highlight">{{ data.horarios.texto }}</p>
        <p class="info-detail">¡Abierto todos los días para ti!</p>
      </div>
      
      <!-- Ubicación -->
      <div class="info-card">
        <div class="info-icon">📍</div>
        <h3>Ubicación</h3>
        <p class="info-highlight">{{ data.contacto.ubicacion.colonia }}, {{ data.contacto.ubicacion.ciudad }}</p>
        <a href="{{ data.contacto.ubicacion.googleMapsUrl }}" 
           target="_blank"
           class="btn btn-outline">
          Ver en Google Maps
        </a>
      </div>
      
      <!-- WhatsApp -->
      <div class="info-card">
        <div class="info-icon">📱</div>
        <h3>WhatsApp</h3>
        <p class="info-highlight">{{ data.contacto.whatsappDisplay }}</p>
        <a href="https://wa.me/{{ whatsappNumber }}?text={{ whatsappMsg }}"
           target="_blank"
           class="btn btn-whatsapp">
          Enviar Mensaje
          {% include "icons/whatsapp.njk" %}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Mapa -->
<section class="mapa-section">
  <div class="container">
    <h2 class="section-title">Encuéntranos Aquí</h2>
    <div class="mapa-container">
      <iframe 
        src="{{ data.contacto.ubicacion.googleMapsEmbed }}"
        width="100%" 
        height="450" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
  </div>
</section>

<!-- CTA Final -->
<section class="cta-final">
  <div class="container">
    <h2>¿Listo para Probar el Mejor Pastor de Acapulco?</h2>
    <p>Haz tu pedido ahora</p>
    <a href="#promociones" 
       class="btn btn-primary btn-xl pulse"
       target="_blank">
      🌮 Ordenar por WhatsApp 👆🏼
    </a>
    <p class="cta-confianza">✓ Pago contra entrega • ✓ Sin costo de envío • ✓ Respuesta inmediata</p>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <img src="{{ data.assets.logo }}" alt="{{ data.nombre }}" class="footer-logo">
    <p>&copy; 2026 {{ data.nombre }}. Todos los derechos reservados.</p>
    <p class="footer-location">{{ data.contacto.ubicacion.direccion }}</p>
    <div class="footer-social">
      <a href="https://wa.me/{{ whatsappNumber }}" target="_blank">WhatsApp</a>
    </div>
  </div>
</footer>
