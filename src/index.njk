        <span class="promo-code">Cupón: {{ data.promociones.cupon.codigo }}</span>
      </div>
    </div>
  </div>
</section-->

<!-- Especialidades Section -->
<section class="especialidades" id="menu">
  <div class="container">
    <h2 class="section-title">Tacos</h2>
    <p class="section-subtitle">Carne de calidad premium • Receta familiar de +25 años</p>
    
    <div class="especialidades-grid">
      {% for item in data.especialidades %}
      <div class="especialidad-card {% if item.destacado %}destacado{% endif %}">
        {% if item.destacado %}
        <div class="destacado-badge">🔥 MÁS VENDIDO</div>
        {% endif %}
        <div class="card-image" style="background-image: url('{{ item.imagen }}');"></div>
        <div class="card-content">
          <h3>{{ item.nombre }}</h3>
          <p>{{ item.descripcion }}</p>
          <a href="https://wa.me/{{ whatsappNumber }}?text=Hola! Quiero ordenar {{ item.nombre }} 🌮" name="btn_especialidades"
             class="btn btn-secondary"
             target="_blank">
            Ordenar Ahora
            {% include "icons/whatsapp.njk" %}
          </a>
        </div>
      </div>
      {% endfor %}
    </div>
    
    <!-- Ver Menú Completo -->
    <div class="menu-completo">
      <h3>¿Quieres ver todo el menú?</h3>
      <a href="https://wa.me/{{ whatsappNumber }}?text=Hola! Me puede mandar su menú 🌮" name="btn_menu"
        class="btn btn-secondary"
        target="_blank">
        Pedir menú
        {% include "icons/whatsapp.njk" %}
      </a>
    </div>
  </div>
</section>

<!-- Proof Section (Prueba Social) -->
