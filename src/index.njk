---
layout: layouts/base.njk
permalink: "/"
---
{% set data = taquerias.gaviotas %}
{% set seoData = data.seo %}
{% set heroImage = data.assets.hero %}
{% set whatsappNumber = data.contacto.whatsapp | replace('+', '') %}
{# {% set whatsappMsg = (data.mensajeWhatsApp ~ ' - Cupón: PLACEHOLDER') | urlencode %} #}
{% set whatsappMsg = (data.mensajeWhatsApp) | urlencode %}

<!-- Hero Section -->
<section class="hero" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.7)), url('{{ data.assets.hero }}');">
  <div class="container">
    <div class="hero-content">
      <img src="{{ data.assets.logo }}" alt="{{ data.nombre }} Logo" class="hero-logo">
      <!--h1 class="hero-title">
        <span class="taqueria-label">Taquería</span>
        <span class="taqueria-name">{{ data.nombre | replace('Taquería ', '') }}</span>
      </h1>
      <p class="hero-lema">{{ data.lema }}</p-->
      
      <!-- Diferenciadires Rápidos -->
      <div class="hero-badges">
        {% for badge in data.diferenciadoresUnicos %}
        <span class="badge">✓ {{ badge }}</span>
        {% endfor %}
      </div>
      
      <!-- CTA Principal -->
      <div class="hero-cta">
        <a href="#promociones"
           class="btn btn-primary btn-lg"
           target="_blank">
          🌮 Haz tu Pedido Ahora 👇🏼
        </a>
        <p class="cta-urgencia">⚡ Abierto hasta las 2:00 AM</p>
      </div>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <a href="#promociones">Desliza para ver PROMOCIONES</a>
    <div class="scroll-arrow">↓</div>
  </div>
</section>

<!-- Promoción Destacada Section -->
<!--section class="promo-destacada-temporal" 
